class Solution {
    public int longestPalindrome(String s) {
        
        int[] freq = new int[128];

        // Store frequency
        for(char ch : s.toCharArray()) {
            freq[ch]++;
        }

        int length = 0;
        boolean oddFound = false;

        for(int count : freq) {

            if(count % 2 == 0) {
                length += count;
            } 
            else {
                length += count - 1;
                oddFound = true;
            }
        }

        // Place one odd character in center
        if(oddFound) {
            length += 1;
        }

        return length;
    }
}
